# Reverse proxy para ATV Paula (HTTPS en el dominio; Docker en 8010/3010).
#
# IMPORTANTE — Mixed Content:
#   Con el sitio en https://app.alsy.com.io el frontend DEBE llamar same-origin
#   (NEXT_PUBLIC_BACKEND_URL vacío → /api-backend). Nginx solo proxea / al Next.
#   Next reescribe /api-backend y /media al contenedor backend.
#
# Si preferís exponer la API en el dominio:
#   location /api/  → backend:8010/api/
#   location /auth/ → backend:8010/auth/
#   location /media/ → backend:8010/media/
#   y NEXT_PUBLIC_BACKEND_URL=https://app.alsy.com.io (rebuild frontend).

server {
    listen 80;
    server_name app.alsy.com.io;
    # Redirigir a HTTPS si tenés certbot (descomentar):
    # return 301 https://$host$request_uri;

    location /media/ {
        proxy_pass http://127.0.0.1:8010/media/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location / {
        proxy_pass http://127.0.0.1:3010;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}
