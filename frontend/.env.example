# URL pública del backend para el navegador (p. ej. https://dominio.com/api).
# Los assets /media/... se resuelven sin el /api final (https://dominio.com/media/...).
# Vacío = proxy same-origin vía /api-backend (dev) y /media/ (prod con Nginx → backend).
NEXT_PUBLIC_BACKEND_URL=
BACKEND_INTERNAL_URL=http://127.0.0.1:8000
# Docker Compose suele definir solo BACKEND_URL (ej. http://backend:8000)
BACKEND_URL=

# Site URL (webhooks Calendly/Fathom en el mismo host)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Anthropic — clasificación IA (server-side)
ANTHROPIC_API_KEY=
