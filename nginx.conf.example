# Reverse proxy para ATV Paula — https://paula.atvos.io
# Docker: backend :8010 · frontend :3010
#
# Opción A (recomendada con NEXT_PUBLIC_BACKEND_URL vacío):
#   /api-backend/* y /media/* pueden ir al frontend (Next reescribe al backend)
#   o, más robusto, Nginx los manda directo al backend (abajo).

server {
    listen 80;
    server_name paula.atvos.io;
    # return 301 https://$host$request_uri;

    # API same-origin: /api-backend/auth/login → backend /auth/login
    location /api-backend/ {
        proxy_pass http://127.0.0.1:8010/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location /media/ {
        proxy_pass http://127.0.0.1:8010/media/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass http://127.0.0.1:3010;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}
